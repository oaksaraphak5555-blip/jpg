<title>คะแนนนักเรียน</title>

<style>

body{
margin:0;
font-family:Arial;
background:#f4f4f4;
transition:0.3s;
}

/* DARK MODE */

.dark{
background:#121212;
color:white;
}

/* ปุ่มเมนู */

.menu-btn{
position:fixed;
top:10px;
left:10px;
font-size:28px;
background:#333;
color:white;
padding:8px 12px;
cursor:pointer;
z-index:1001;
}

/* เมนู */

.sidebar{
position:fixed;
top:0;
left:-250px;
width:250px;
height:100%;
background:#222;
transition:0.3s;
padding-top:60px;
}

.sidebar.show{
left:0;
}

.sidebar a{
display:block;
padding:12px 20px;
color:white;
text-decoration:none;
}

.sidebar a:hover{
background:#444;
}

/* ปุ่มโหมด */

.darkbtn{
position:fixed;
top:10px;
right:10px;
padding:8px 12px;
background:#333;
color:white;
cursor:pointer;
}

/* เนื้อหา */

.content{
padding:60px 20px;
text-align:center;
}

/* ค้นหา */

input{
padding:10px;
width:250px;
margin-bottom:20px;
}

/* ตาราง */

table{
width:100%;
border-collapse:collapse;
background:white;
}

.dark table{
background:#222;
}

th,td{
border:1px solid #ccc;
padding:10px;
}

th{
background:#4CAF50;
color:white;
}

/* แชท */

#chatBox{
height:250px;
border:1px solid #ccc;
overflow-y:auto;
padding:10px;
margin-top:20px;
background:white;
}

.dark #chatBox{
background:#333;
}

</style>
</head>

